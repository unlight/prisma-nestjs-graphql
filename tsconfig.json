{
  "compilerOptions": {
    "target": "es2024",
    "rewriteRelativeImportExtensions": true,
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "importHelpers": true,
    "strict": true,
    "noImplicitAny": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "allowImportingTsExtensions": true,
    "rootDir": ".",
    "outDir": "dist",
    "pretty": true,
    "esModuleInterop": true,
    "removeComments": false,
    "sourceMap": false,
    "declaration": false,
    "declarationMap": false,
    "skipLibCheck": true,
    "lib": ["esnext"]
  },
  "include": ["src", "prisma/nestgraphql.config.mjs"]
  // "include": ["src", "example", "@generated"]
}
